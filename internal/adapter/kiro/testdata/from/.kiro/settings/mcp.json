{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {
        "API_TOKEN": "${API_TOKEN}"
      },
      "autoApprove": ["fetch"],
      "disabled": false
    },
    "remote": {
